[Trigger]
Type = Package
Operation = Install
Operation = Remove
Operation = Package
Target = *

[Action]
Description = Removing non lts linux directories in /usr/lib/modules...
When = PostTransaction
Exec = find /usr/lib/modules/ -maxdepth 2 -type ! -name "*-lts" -exec rm -d {} +; touch /root/test_to_work
